# ─────────────────────────────────────────────────────────────────────────────
# DEVELOPMENT DEFAULTS — DO NOT use these values in production.
#
# Both services fail to start if SECRET_KEY or PROCUREMENT_API_TOKEN are
# missing (no in-code defaults). Copy this file to `.env` for local dev,
# but generate fresh values for any non-local deployment:
#
#   SECRET_KEY:            python -c "import secrets; print(secrets.token_urlsafe(64))"
#   PROCUREMENT_API_TOKEN: python -c "import secrets; print(secrets.token_urlsafe(32))"
# ─────────────────────────────────────────────────────────────────────────────

DEBUG=True
SECRET_KEY=devsecret
ALLOWED_HOSTS=*
PROCUREMENT_API_TOKEN=devtoken
